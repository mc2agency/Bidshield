# ===========================================
# MC2 Estimating - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# -------------------------------------------
# Convex Backend
# -------------------------------------------
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# -------------------------------------------
# Clerk Authentication
# -------------------------------------------
# Get these from: https://dashboard.clerk.com
# Use test keys for development, live keys for production
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Clerk JWT Issuer Domain (for Convex auth)
# Development: https://your-instance.clerk.accounts.dev
# Production with custom domain: https://clerk.mc2estimating.com
CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev

# Clerk Webhook Secret (for webhook verification)
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# Clerk URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# -------------------------------------------
# HeyGen API (AI Video)
# -------------------------------------------
# Get your API key from: https://app.heygen.com/settings/api
# Required plan: Creator ($24/mo) or higher
HEYGEN_API_KEY=sk_xxxxx

# -------------------------------------------
# Gumroad (Payments)
# -------------------------------------------
# Webhook secret for verifying Gumroad webhooks
GUMROAD_WEBHOOK_SECRET=your_webhook_secret

# -------------------------------------------
# Google Search Console (SEO)
# -------------------------------------------
# Get verification code from Google Search Console
# Go to: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code

# -------------------------------------------
# Optional: Video Hosting
# -------------------------------------------
VIMEO_ACCESS_TOKEN=your_vimeo_token_here

# -------------------------------------------
# Optional: Email Marketing
# -------------------------------------------
CONVERTKIT_API_KEY=your_convertkit_key_here

# ===========================================
# PRODUCTION CHECKLIST
# ===========================================
# Before deploying to production:
# 1. Replace all test/dev keys with production keys
# 2. Set these environment variables in Vercel Dashboard
# 3. Update CLERK_JWT_ISSUER_DOMAIN if using custom Clerk domain
# 4. Add NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION for SEO
# 5. Verify webhook secrets are set for Clerk and Gumroad
