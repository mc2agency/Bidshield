# ============================================================
# BidShield / MC2 Estimating — Environment Variables
# Copy this file to .env.local and fill in your real values
# ============================================================

# ── CONVEX ──────────────────────────────────────────────────
# From: https://dashboard.convex.dev → your project → Settings
NEXT_PUBLIC_CONVEX_URL=https://YOUR_PROJECT.convex.cloud

# ── CLERK ───────────────────────────────────────────────────
# From: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Clerk JWT Issuer Domain — from: Clerk Dashboard → JWT Templates → convex → Issuer
# Format: https://YOUR_CLERK_DOMAIN.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://helpful-jackal-16.clerk.accounts.dev

# Clerk webhook secret — from: Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ── STRIPE ──────────────────────────────────────────────────
# From: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...

# Price IDs — from: Stripe Dashboard → Products → BidShield Pro → Pricing
# Create two prices: Monthly ($149) and Annual ($1,490)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...

# Stripe webhook secret — from: Stripe Dashboard → Webhooks → your endpoint → Signing Secret
# Webhook endpoint: https://mc2estimating.com/api/bidshield/webhook
# Events to enable: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...

# ── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_URL=https://mc2estimating.com
NEXT_PUBLIC_APP_URL=https://mc2estimating.com

# ── RESEND (Email) ──────────────────────────────────────────
# From: https://resend.com → API Keys
# IMPORTANT: Also add RESEND_API_KEY to Convex dashboard env vars:
#   https://dashboard.convex.dev → your project → Settings → Environment Variables
RESEND_API_KEY=re_...

# ── ANTHROPIC ───────────────────────────────────────────────
# From: https://console.anthropic.com → API Keys
# Used for PDF price sheet extraction (Datasheets → Upload Price Sheet)
ANTHROPIC_API_KEY=sk-ant-...

# ── OPTIONAL ────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── UPSTASH REDIS (recommended for distributed rate limiting) ─
# Without these, rate limiting falls back to in-memory LRU (per-instance only).
# Create a database at https://console.upstash.com and install
# @upstash/ratelimit + @upstash/redis to enable distributed rate limiting.
# UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
# UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# GA4 Measurement ID — from: Google Analytics → Admin → Data Streams → your stream → Measurement ID
# Format: G-XXXXXXXXXX
# If blank, all GA4 events are silently disabled (safe default)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
